# Pick a random interesting fractal view into reply-style global array name
# Sets: _SUITE_FRACTAL_ROWS (the chosen art) and _SUITE_FRACTAL_VIEW (name)
_suite_pick_fractal() {
    local n=${#_SUITE_FRACTAL_NAMES[@]}
    local idx=$(( (RANDOM % n) + 1 ))
    local name=${_SUITE_FRACTAL_NAMES[idx]}
    typeset -g _SUITE_FRACTAL_VIEW=$name
    # Copy chosen view into the active rows array (nameref-style via eval â€” fixed allowlist)
    case $name in
        seahorse)  _SUITE_FRACTAL_ROWS=("${_SUITE_FRACTAL_SEAHORSE[@]}") ;;
        spiral)    _SUITE_FRACTAL_ROWS=("${_SUITE_FRACTAL_SPIRAL[@]}") ;;
        juliaish)  _SUITE_FRACTAL_ROWS=("${_SUITE_FRACTAL_JULIAISH[@]}") ;;
        feather)   _SUITE_FRACTAL_ROWS=("${_SUITE_FRACTAL_FEATHER[@]}") ;;
        lightning) _SUITE_FRACTAL_ROWS=("${_SUITE_FRACTAL_LIGHTNING[@]}") ;;
        valley)    _SUITE_FRACTAL_ROWS=("${_SUITE_FRACTAL_VALLEY[@]}") ;;
        tendril)   _SUITE_FRACTAL_ROWS=("${_SUITE_FRACTAL_TENDRIL[@]}") ;;
        double_sp) _SUITE_FRACTAL_ROWS=("${_SUITE_FRACTAL_DOUBLE_SP[@]}") ;;
        *)         _SUITE_FRACTAL_ROWS=("${_SUITE_FRACTAL_SEAHORSE[@]}") ;;
    esac
}


# Resolve live terminal geometry
_suite_term_size() {
    local stty_out
    if [[ -n ${COLUMNS:-} && $COLUMNS -gt 0 ]]; then
        _SUITE_COLS=$COLUMNS
    elif stty_out=$(stty size </dev/tty 2>/dev/null); then
        _SUITE_COLS=${stty_out##* }
    else
        _SUITE_COLS=$(tput cols 2>/dev/null || print -r -- 80)
    fi

    if [[ -n ${LINES:-} && $LINES -gt 0 ]]; then
        _SUITE_ROWS=$LINES
    elif [[ -n ${stty_out:-} ]]; then
        _SUITE_ROWS=${stty_out%% *}
    elif stty_out=$(stty size </dev/tty 2>/dev/null); then
        _SUITE_ROWS=${stty_out%% *}
    else
        _SUITE_ROWS=$(tput lines 2>/dev/null || print -r -- 24)
    fi

    (( _SUITE_COLS < 40 )) && _SUITE_COLS=40
    (( _SUITE_ROWS < 12 )) && _SUITE_ROWS=12
}

# Repeat each character sx times (plain loop â€” nested ${(l:...)} breaks on $ch)
_suite_scale_row() {
    local row=$1 sx=$2 width=$3
    local out='' i j ch
    if (( sx <= 1 )); then
        out=$row
    else
        for (( i = 1; i <= ${#row}; i++ )); do
            ch=${row[i]}
            for (( j = 0; j < sx; j++ )); do
                out+=$ch
            done
        done
    fi

    local len=${#out}
    if (( len > width )); then
        local start=$(( (len - width) / 2 + 1 ))
        out=${out[start,start+width-1]}
    elif (( len < width )); then
        local left=$(( (width - len) / 2 ))
        local right=$(( width - len - left ))
        out=${(l:left:)}${out}${(r:right:)}
    fi
    print -rn -- "$out"
}

# Compute integer scale factors from window size.
_suite_compute_scale() {
    local base_w=$1 base_h=$2
    local target_w=$(( _SUITE_COLS - 2 ))
    (( target_w < 36 )) && target_w=36

    local budget_h=$(( _SUITE_ROWS - 8 ))
    (( budget_h < 8 )) && budget_h=8

    local sx=$(( target_w / base_w ))
    local sy=$(( budget_h / base_h ))
    (( sx < 1 )) && sx=1
    (( sy < 1 )) && sy=1

    (( _SUITE_COLS >= 90 && sx < 2 )) && sx=2
    (( _SUITE_COLS >= 140 && sx < 3 )) && sx=3
    (( _SUITE_ROWS >= 26 && sy < 2 )) && sy=2
    (( _SUITE_ROWS >= 44 && sy < 3 )) && sy=3

    (( sx > 4 )) && sx=4
    (( sy > 3 )) && sy=3

    while (( base_w * sx > (target_w * 115 / 100) && sx > 1 )); do (( sx-- )); done
    while (( base_h * sy > budget_h + 6 && sy > 1 )); do (( sy-- )); done

    _SUITE_SX=$sx
    _SUITE_SY=$sy
    _SUITE_ART_W=$target_w
}

_suite_scale_art() {
    local -a src=("$@")
    local base_w=${#src[1]}
    local base_h=${#src[@]}
    (( base_w < 1 )) && return 0

    _suite_compute_scale "$base_w" "$base_h"

    local row scaled i
    for row in "${src[@]}"; do
        scaled=$(_suite_scale_row "$row" "$_SUITE_SX" "$_SUITE_ART_W")
        for (( i = 1; i <= _SUITE_SY; i++ )); do
            print -r -- "$scaled"
        done
    done
}
